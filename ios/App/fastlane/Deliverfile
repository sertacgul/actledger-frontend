# Deliverfile - App Store submission configuration

# App metadata
app_identifier("com.ataolaitech.actledger")
username("changeme@example.com")

# Use App Store Connect API key (same as TestFlight uploads)
# Keys are passed via environment variables in CI

# Metadata path
metadata_path("./fastlane/metadata")
screenshots_path("./fastlane/screenshots")

# Submission settings
submit_for_review(false)
automatic_release(false)
force(true)

# Skip uploading screenshots if folder is empty
skip_screenshots(false)

# Price tier (free app)
price_tier(0)

# Primary category
primary_category("MZGenre.Business")

# App rating - set manually in App Store Connect
# (Fastlane doesn't support newer required fields like healthOrWellnessTopics)

# Availability
phased_release(true)

# Copyright
copyright("2026 ATAOL AI Techs")
